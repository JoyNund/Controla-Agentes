# Contraseña para login en la web app (admin@controla.digital)
APP_PASSWORD=controla2024

# --- MOTORES DE IA ---

# Deepseek por defecto (recomendado para agentes de ventas)
# Obtener en: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-...

# Opcional: modelo Deepseek (por defecto: deepseek-chat)
# DEEPSEEK_MODEL=deepseek-chat

# OpenAI (GPT-4o, GPT-3.5-turbo)
# Obtener en: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Google Gemini (gemini-1.5-pro, gemini-1.5-flash)
# Obtener en: https://aistudio.google.com/apikey
# GEMINI_API_KEY=...

# Llama (via Groq - recomendado por velocidad)
# Obtener en: https://console.groq.com/keys
# GROQ_API_KEY=...
# O usa LLAMA_API_KEY si usas otro proveedor (Together, etc.)
# LLAMA_API_KEY=...

# --- PUERTOS (importante si ya tienes otras apps en el servidor) ---
# Puerto del BOT (instancia Baileys + portal QR). Sin esto, el portal usa PORT o 3000.
# Recomendado: BOT_PORT=3848 (o otro libre) para no chocar con la web ni otras apps.
# BOT_PORT=3848

# Puerto de la web app CONTROLA.agentes (API + frontend). Por defecto 3847.
# WEBAPP_PORT=3847

# Si el bot corre en otro host/puerto que la API, indica la URL de la API para el monitor de chats:
# WEBAPP_API_URL=http://localhost:3847

# --- DEBUG ---
# Mostrar firma del modelo en cada respuesta (para testing)
# DEBUG_MODE=true
